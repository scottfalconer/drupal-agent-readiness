{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://drupal.org/agent-readiness/benchmark-experiment-v1.schema.json",
  "title": "Drupal Agent Readiness Benchmark Experiment v1",
  "type": "object",
  "required": [
    "schema_version",
    "experiment_id",
    "registered_at",
    "registration",
    "governance",
    "lane",
    "task",
    "prompt_composition",
    "reference_agent_stack",
    "substrate",
    "state_capture",
    "arms",
    "evaluation",
    "budget",
    "cost_measurement",
    "outcome_metrics",
    "comparison",
    "execution_plan",
    "inference_scope",
    "sampling_design",
    "claim_plan",
    "exclusion_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "drupal_agent_readiness.benchmark_experiment.v1"
    },
    "experiment_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*@v[1-9][0-9]*$"
    },
    "registered_at": {
      "type": "string",
      "format": "date-time"
    },
    "registration": {
      "type": "object",
      "required": ["manifest_path", "protocol"],
      "properties": {
        "manifest_path": {"$ref": "#/$defs/relativeUri"},
        "protocol": {"$ref": "#/$defs/artifactPin"}
      },
      "additionalProperties": false
    },
    "governance": {"$ref": "#/$defs/governancePins"},
    "lane": {
      "type": "string",
      "enum": ["fixed_regression", "frontier_observation"]
    },
    "task": {"$ref": "#/$defs/taskPin"},
    "prompt_composition": {"$ref": "#/$defs/promptComposition"},
    "reference_agent_stack": {"$ref": "#/$defs/agentStack"},
    "substrate": {"$ref": "#/$defs/substrate"},
    "state_capture": {"$ref": "#/$defs/stateCapturePlan"},
    "arms": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/arm"}
    },
    "evaluation": {"$ref": "#/$defs/evaluationPins"},
    "budget": {"$ref": "#/$defs/budget"},
    "cost_measurement": {"$ref": "#/$defs/costMeasurementPlan"},
    "outcome_metrics": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/outcomeMetricDefinition"}
    },
    "comparison": {"$ref": "#/$defs/comparison"},
    "execution_plan": {"$ref": "#/$defs/executionPlan"},
    "inference_scope": {"$ref": "#/$defs/inferenceScope"},
    "sampling_design": {"$ref": "#/$defs/samplingDesign"},
    "claim_plan": {"$ref": "#/$defs/claimPlan"},
    "exclusion_policy": {"$ref": "#/$defs/exclusionPolicy"}
  },
  "additionalProperties": false,
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "relativeUri": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/).+$"
    },
    "artifactPin": {
      "type": "object",
      "required": ["uri", "sha256", "media_type", "byte_size"],
      "properties": {
        "uri": {"$ref": "#/$defs/relativeUri"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "media_type": {"type": "string", "minLength": 1},
        "byte_size": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "roleArtifactPin": {
      "type": "object",
      "required": [
        "uri",
        "sha256",
        "media_type",
        "byte_size",
        "evidence_role",
        "visibility",
        "audience"
      ],
      "properties": {
        "uri": {"$ref": "#/$defs/relativeUri"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "media_type": {"type": "string", "minLength": 1},
        "byte_size": {"type": "integer", "minimum": 1},
        "evidence_role": {
          "type": "string",
          "enum": [
            "task_prompt",
            "system_prompt",
            "output_schema",
            "render_inputs",
            "ground_truth",
            "evaluator_implementation",
            "evaluation_rubric",
            "scoring_implementation"
          ]
        },
        "visibility": {
          "type": "string",
          "enum": ["agent_visible", "withheld_from_agent"]
        },
        "audience": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["agent", "harness", "evaluator", "auditor"]
          }
        }
      },
      "additionalProperties": false
    },
    "versionedArtifact": {
      "type": "object",
      "required": ["id", "version", "artifact"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "artifact": {"$ref": "#/$defs/artifactPin"}
      },
      "additionalProperties": false
    },
    "governancePins": {
      "type": "object",
      "required": [
        "coverage_claim_id",
        "task_family_id",
        "improvement_record_id",
        "registry_design"
      ],
      "properties": {
        "coverage_claim_id": {"type": "string", "minLength": 1},
        "task_family_id": {"type": "string", "minLength": 1},
        "improvement_record_id": {"type": "string", "minLength": 1},
        "registry_design": {"$ref": "#/$defs/versionedArtifact"}
      },
      "additionalProperties": false
    },
    "versionedRoleArtifact": {
      "type": "object",
      "required": ["id", "version", "artifact"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "artifact": {"$ref": "#/$defs/roleArtifactPin"}
      },
      "additionalProperties": false
    },
    "taskPin": {
      "type": "object",
      "required": [
        "id",
        "version",
        "lifecycle_stages",
        "definition",
        "prompt",
        "ground_truth"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "lifecycle_stages": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/lifecycleStage"}
        },
        "definition": {"$ref": "#/$defs/artifactPin"},
        "prompt": {"$ref": "#/$defs/roleArtifactPin"},
        "ground_truth": {"$ref": "#/$defs/roleArtifactPin"}
      },
      "additionalProperties": false
    },
    "promptComposition": {
      "type": "object",
      "required": ["algorithm", "renderer", "render_inputs"],
      "properties": {
        "algorithm": {
          "enum": [
            "canonical_prompt_envelope_v1",
            "canonical_operator_prompt_envelope_v1"
          ]
        },
        "renderer": {"$ref": "#/$defs/versionedArtifact"},
        "render_inputs": {"$ref": "#/$defs/roleArtifactPin"}
      },
      "additionalProperties": false
    },
    "modelBackendIdentityContract": {
      "type": "object",
      "required": [
        "mode",
        "expected_backend_identity",
        "attestation_contract",
        "local_model_artifact",
        "runner_attestation_contract",
        "required_invocation_argument"
      ],
      "properties": {
        "mode": {
          "enum": [
            "provider_attested_snapshot",
            "local_model_artifact",
            "held_selector"
          ]
        },
        "expected_backend_identity": {
          "anyOf": [
            {"type": "string", "minLength": 1},
            {"type": "null"}
          ]
        },
        "attestation_contract": {
          "anyOf": [
            {"$ref": "#/$defs/versionedArtifact"},
            {"type": "null"}
          ]
        },
        "local_model_artifact": {
          "anyOf": [
            {"$ref": "#/$defs/artifactPin"},
            {"type": "null"}
          ]
        },
        "runner_attestation_contract": {
          "anyOf": [
            {"$ref": "#/$defs/versionedArtifact"},
            {"type": "null"}
          ]
        },
        "required_invocation_argument": {
          "anyOf": [
            {"type": "string", "minLength": 1},
            {"type": "null"}
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"mode": {"const": "provider_attested_snapshot"}},
            "required": ["mode"]
          },
          "then": {
            "properties": {
              "expected_backend_identity": {"type": "string", "minLength": 1},
              "attestation_contract": {"$ref": "#/$defs/versionedArtifact"},
              "local_model_artifact": {"type": "null"},
              "runner_attestation_contract": {"type": "null"},
              "required_invocation_argument": {"type": "null"}
            }
          }
        },
        {
          "if": {
            "properties": {"mode": {"const": "local_model_artifact"}},
            "required": ["mode"]
          },
          "then": {
            "properties": {
              "expected_backend_identity": {"$ref": "#/$defs/sha256"},
              "attestation_contract": {"type": "null"},
              "local_model_artifact": {"$ref": "#/$defs/artifactPin"},
              "runner_attestation_contract": {"$ref": "#/$defs/versionedArtifact"},
              "required_invocation_argument": {"type": "string", "minLength": 1}
            }
          }
        },
        {
          "if": {
            "properties": {"mode": {"const": "held_selector"}},
            "required": ["mode"]
          },
          "then": {
            "properties": {
              "expected_backend_identity": {"type": "null"},
              "attestation_contract": {"type": "null"},
              "local_model_artifact": {"type": "null"},
              "runner_attestation_contract": {"type": "null"},
              "required_invocation_argument": {"type": "null"}
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "agentStack": {
      "type": "object",
      "required": [
        "agent",
        "model",
        "harness",
        "system_prompt",
        "output_schema",
        "tools",
        "permissions"
      ],
      "properties": {
        "agent": {"$ref": "#/$defs/versionedArtifact"},
        "model": {
          "type": "object",
          "required": [
            "provider",
            "id",
            "snapshot",
            "inference_parameters",
            "backend_identity_contract"
          ],
          "properties": {
            "provider": {"type": "string", "minLength": 1},
            "id": {"type": "string", "minLength": 1},
            "snapshot": {"type": "string", "minLength": 1},
            "inference_parameters": {"$ref": "#/$defs/artifactPin"},
            "backend_identity_contract": {
              "$ref": "#/$defs/modelBackendIdentityContract"
            }
          },
          "additionalProperties": false
        },
        "harness": {"$ref": "#/$defs/versionedArtifact"},
        "system_prompt": {"$ref": "#/$defs/roleArtifactPin"},
        "output_schema": {"$ref": "#/$defs/roleArtifactPin"},
        "tools": {
          "type": "array",
          "items": {"$ref": "#/$defs/versionedArtifact"}
        },
        "permissions": {
          "type": "object",
          "required": [
            "profile_id",
            "policy",
            "allowed_capabilities",
            "denied_capabilities",
            "network_access",
            "filesystem_scope"
          ],
          "properties": {
            "profile_id": {"type": "string", "minLength": 1},
            "policy": {"$ref": "#/$defs/artifactPin"},
            "allowed_capabilities": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            },
            "denied_capabilities": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            },
            "network_access": {"type": "boolean"},
            "filesystem_scope": {
              "type": "string",
              "enum": ["none", "fixture_only", "workspace", "unrestricted"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "componentPin": {
      "type": "object",
      "required": ["kind", "name", "version", "revision", "tree_sha256"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["core", "cms", "profile", "module", "theme"]
        },
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "revision": {"type": "string", "minLength": 1},
        "tree_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "codeState": {
      "type": "object",
      "required": [
        "core",
        "components",
        "composer_lock_sha256",
        "extensions_manifest_sha256",
        "codebase_tree_sha256",
        "sources",
        "manifest"
      ],
      "properties": {
        "core": {"$ref": "#/$defs/componentPin"},
        "components": {
          "type": "array",
          "items": {"$ref": "#/$defs/componentPin"}
        },
        "composer_lock_sha256": {"$ref": "#/$defs/sha256"},
        "extensions_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "codebase_tree_sha256": {"$ref": "#/$defs/sha256"},
        "sources": {
          "type": "object",
          "required": ["composer_lock", "extensions_manifest", "codebase"],
          "properties": {
            "composer_lock": {"$ref": "#/$defs/artifactPin"},
            "extensions_manifest": {"$ref": "#/$defs/artifactPin"},
            "codebase": {"$ref": "#/$defs/artifactPin"}
          },
          "additionalProperties": false
        },
        "manifest": {"$ref": "#/$defs/artifactPin"}
      },
      "additionalProperties": false
    },
    "siteState": {
      "type": "object",
      "required": [
        "fixture_id",
        "database_sha256",
        "active_config_sha256",
        "public_files_sha256",
        "private_files_sha256",
        "composite_sha256",
        "sources",
        "manifest"
      ],
      "properties": {
        "fixture_id": {"type": "string", "minLength": 1},
        "database_sha256": {"$ref": "#/$defs/sha256"},
        "active_config_sha256": {"$ref": "#/$defs/sha256"},
        "public_files_sha256": {"$ref": "#/$defs/sha256"},
        "private_files_sha256": {"$ref": "#/$defs/sha256"},
        "composite_sha256": {"$ref": "#/$defs/sha256"},
        "sources": {
          "type": "object",
          "required": ["database", "active_config", "public_files", "private_files"],
          "properties": {
            "database": {"$ref": "#/$defs/artifactPin"},
            "active_config": {"$ref": "#/$defs/artifactPin"},
            "public_files": {"$ref": "#/$defs/artifactPin"},
            "private_files": {"$ref": "#/$defs/artifactPin"}
          },
          "additionalProperties": false
        },
        "manifest": {"$ref": "#/$defs/artifactPin"}
      },
      "additionalProperties": false
    },
    "drupalState": {
      "type": "object",
      "required": ["code", "site"],
      "properties": {
        "code": {"$ref": "#/$defs/codeState"},
        "site": {"$ref": "#/$defs/siteState"}
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "required": [
        "php_version",
        "database_driver",
        "database_version",
        "os_image_digest",
        "container_image_digest"
      ],
      "properties": {
        "php_version": {"type": "string", "minLength": 1},
        "database_driver": {"type": "string", "minLength": 1},
        "database_version": {"type": "string", "minLength": 1},
        "os_image_digest": {"$ref": "#/$defs/sha256"},
        "container_image_digest": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "substrate": {
      "type": "object",
      "required": [
        "substrate_id",
        "starting_site_seed",
        "owner_attestation",
        "runtime"
      ],
      "properties": {
        "substrate_id": {"type": "string", "minLength": 1},
        "starting_site_seed": {"$ref": "#/$defs/siteState"},
        "owner_attestation": {
          "anyOf": [
            {"$ref": "#/$defs/artifactPin"},
            {"type": "null"}
          ]
        },
        "runtime": {"$ref": "#/$defs/runtime"}
      },
      "additionalProperties": false
    },
    "stateCapturePlan": {
      "type": "object",
      "required": ["collector", "protocol"],
      "properties": {
        "collector": {"$ref": "#/$defs/versionedArtifact"},
        "protocol": {"$ref": "#/$defs/artifactPin"}
      },
      "additionalProperties": false
    },
    "treatment": {
      "type": "object",
      "required": ["id", "kind", "artifact"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "kind": {
          "type": "string",
          "enum": [
            "none",
            "drupal_code",
            "site_configuration",
            "documentation",
            "combined"
          ]
        },
        "artifact": {"$ref": "#/$defs/artifactPin"}
      },
      "additionalProperties": false
    },
    "arm": {
      "type": "object",
      "required": ["arm_id", "role", "treatment", "drupal_state"],
      "properties": {
        "arm_id": {"type": "string", "minLength": 1},
        "role": {
          "type": "string",
          "enum": ["pre", "post", "observation"]
        },
        "treatment": {"$ref": "#/$defs/treatment"},
        "drupal_state": {"$ref": "#/$defs/drupalState"}
      },
      "additionalProperties": false
    },
    "evaluationAssurance": {
      "type": "object",
      "required": ["mode", "receipt_contract", "trusted_issuer"],
      "properties": {
        "mode": {"const": "trusted_execution_receipt"},
        "receipt_contract": {"$ref": "#/$defs/artifactPin"},
        "trusted_issuer": {"$ref": "#/$defs/versionedArtifact"}
      },
      "additionalProperties": false
    },
    "evaluationPins": {
      "type": "object",
      "required": [
        "evaluator",
        "rubric",
        "scoring",
        "verdict_metric_id",
        "assurance"
      ],
      "properties": {
        "evaluator": {"$ref": "#/$defs/versionedRoleArtifact"},
        "rubric": {"$ref": "#/$defs/versionedRoleArtifact"},
        "scoring": {"$ref": "#/$defs/versionedRoleArtifact"},
        "verdict_metric_id": {"type": "string", "minLength": 1},
        "assurance": {"$ref": "#/$defs/evaluationAssurance"}
      },
      "additionalProperties": false
    },
    "budget": {
      "type": "object",
      "required": [
        "wall_time_ms",
        "input_tokens",
        "output_tokens",
        "tool_calls",
        "human_interventions",
        "cost_microusd"
      ],
      "properties": {
        "wall_time_ms": {"type": "integer", "minimum": 1},
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "tool_calls": {"type": "integer", "minimum": 0},
        "human_interventions": {"type": "integer", "minimum": 0},
        "cost_microusd": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "costMeasurementPlan": {
      "type": "object",
      "required": ["mode", "price_schedule"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["actual_provider_cost", "derived_from_usage", "unavailable"]
        },
        "price_schedule": {
          "anyOf": [
            {"$ref": "#/$defs/artifactPin"},
            {"type": "null"}
          ]
        }
      },
      "additionalProperties": false
    },
    "outcomeMetricDefinition": {
      "type": "object",
      "required": [
        "metric_id",
        "kind",
        "unit",
        "direction",
        "denominator_unit",
        "aggregation"
      ],
      "properties": {
        "metric_id": {"type": "string", "minLength": 1},
        "kind": {
          "type": "string",
          "enum": ["binary", "count", "rate", "score", "duration", "cost"]
        },
        "unit": {"type": "string", "minLength": 1},
        "direction": {
          "type": "string",
          "enum": ["higher_is_better", "lower_is_better"]
        },
        "denominator_unit": {"type": "string", "minLength": 1},
        "aggregation": {
          "type": "string",
          "enum": ["mean", "sum", "proportion"]
        }
      },
      "additionalProperties": false
    },
    "comparison": {
      "type": "object",
      "required": [
        "mode",
        "order_policy",
        "assignment_seed_sha256",
        "allowed_changed_paths"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["paired_pre_post", "unpaired_observation"]
        },
        "pre_arm_id": {"type": "string", "minLength": 1},
        "post_arm_id": {"type": "string", "minLength": 1},
        "order_policy": {
          "type": "string",
          "enum": [
            "counterbalanced",
            "pre_then_post",
            "post_then_pre",
            "not_applicable"
          ]
        },
        "assignment_seed_sha256": {"$ref": "#/$defs/sha256"},
        "allowed_changed_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^/(code|site)/.+"
          }
        }
      },
      "additionalProperties": false
    },
    "lifecycleStage": {
      "type": "string",
      "enum": [
        "choose_onboard",
        "connect",
        "understand",
        "plan_clarify",
        "act",
        "verify",
        "recover",
        "handoff"
      ]
    },
    "executionSlot": {
      "type": "object",
      "required": ["slot_id", "arm_id", "order"],
      "properties": {
        "slot_id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$"
        },
        "arm_id": {"type": "string", "minLength": 1},
        "order": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "attemptRosterEntry": {
      "type": "object",
      "required": ["index", "pair_id", "unit_id", "executions"],
      "properties": {
        "index": {"type": "integer", "minimum": 1},
        "pair_id": {"type": ["string", "null"]},
        "unit_id": {"type": "string", "minLength": 1},
        "executions": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/executionSlot"}
        }
      },
      "additionalProperties": false
    },
    "executionPlan": {
      "type": "object",
      "required": ["attempt_roster", "stopping_rule"],
      "properties": {
        "attempt_roster": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/attemptRosterEntry"}
        },
        "stopping_rule": {
          "type": "object",
          "required": [
            "kind",
            "required_resolved_slots",
            "allow_replacements",
            "on_exclusion"
          ],
          "properties": {
            "kind": {"const": "fixed_census"},
            "required_resolved_slots": {"type": "integer", "minimum": 1},
            "allow_replacements": {"const": false},
            "on_exclusion": {"const": "no_claim"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "confidencePlan": {
      "type": "object",
      "required": ["method", "level", "tail"],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "none",
            "paired_hoeffding_lower",
            "bootstrap_percentile"
          ]
        },
        "level": {
          "type": "number",
          "exclusiveMinimum": 0.5,
          "exclusiveMaximum": 1.0
        },
        "tail": {
          "type": "string",
          "enum": ["none", "one_sided_lower", "two_sided"]
        },
        "resamples": {"type": "integer", "minimum": 1000},
        "seed_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "inferenceScope": {
      "type": "object",
      "required": ["kind", "target_population", "generalization_boundary"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["registered_roster_only", "target_population"]
        },
        "target_population": {"type": ["string", "null"]},
        "generalization_boundary": {"$ref": "#/$defs/artifactPin"}
      },
      "additionalProperties": false
    },
    "samplingDesign": {
      "type": "object",
      "required": [
        "sampling_unit",
        "selection_method",
        "independence_assumption",
        "independence_basis"
      ],
      "properties": {
        "sampling_unit": {
          "type": "string",
          "enum": ["complete_pair", "included_run"]
        },
        "selection_method": {
          "type": "string",
          "enum": ["fixed_registered_census", "independent_random_sample"]
        },
        "independence_assumption": {
          "type": "string",
          "enum": ["independent_units", "correlated_or_unknown"]
        },
        "independence_basis": {"$ref": "#/$defs/artifactPin"}
      },
      "additionalProperties": false
    },
    "guardrailSource": {
      "type": "object",
      "required": ["kind", "metric_id"],
      "properties": {
        "kind": {"type": "string", "enum": ["outcome_metric", "cost"]},
        "metric_id": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "guardrailRule": {
      "type": "object",
      "required": ["statistic", "operator", "threshold"],
      "properties": {
        "statistic": {
          "type": "string",
          "enum": [
            "maximum_all",
            "maximum_post",
            "minimum_post",
            "mean_post_minus_pre"
          ]
        },
        "operator": {"type": "string", "enum": ["at_most", "at_least"]},
        "threshold": {"type": "number"}
      },
      "additionalProperties": false
    },
    "guardrail": {
      "type": "object",
      "required": ["guardrail_id", "source", "rules"],
      "properties": {
        "guardrail_id": {"type": "string", "minLength": 1},
        "source": {"$ref": "#/$defs/guardrailSource"},
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/guardrailRule"}
        }
      },
      "additionalProperties": false
    },
    "claimPlan": {
      "type": "object",
      "required": [
        "claim_class",
        "primary_metric_id",
        "estimand",
        "planned_denominator",
        "denominator_unit",
        "confidence",
        "minimum_favorable_effect",
        "decision_rule",
        "sample_size_rationale",
        "guardrails"
      ],
      "properties": {
        "claim_class": {
          "type": "string",
          "enum": ["exploratory", "descriptive", "comparative", "causal"]
        },
        "primary_metric_id": {"type": "string", "minLength": 1},
        "estimand": {
          "type": "string",
          "enum": ["mean_paired_difference", "mean_observed_value"]
        },
        "planned_denominator": {"type": "integer", "minimum": 1},
        "denominator_unit": {"type": "string", "minLength": 1},
        "confidence": {"$ref": "#/$defs/confidencePlan"},
        "minimum_favorable_effect": {"type": "number", "minimum": 0},
        "decision_rule": {
          "type": "string",
          "enum": [
            "confidence_lower_bound_at_least_minimum",
            "descriptive_only"
          ]
        },
        "sample_size_rationale": {"$ref": "#/$defs/artifactPin"},
        "guardrails": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/guardrail"}
        }
      },
      "additionalProperties": false
    },
    "exclusionCode": {
      "type": "object",
      "required": ["code", "description"],
      "properties": {
        "code": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "description": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "exclusionPolicy": {
      "type": "object",
      "required": ["locked_at", "policy", "codes"],
      "properties": {
        "locked_at": {"type": "string", "format": "date-time"},
        "policy": {"$ref": "#/$defs/artifactPin"},
        "codes": {
          "type": "array",
          "items": {"$ref": "#/$defs/exclusionCode"}
        }
      },
      "additionalProperties": false
    }
  }
}
