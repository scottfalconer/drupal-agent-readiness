{
  "schema_version": "1.2.0",
  "registry_id": "drupal-agent-readiness-task-families-v1",
  "lifecycle_target_contracts": [
    {
      "id": "plan-clarify-observable-contract",
      "lifecycle_stage": "plan_clarify",
      "measurement_state": "target_not_executed",
      "task_family_ids": ["supported_cold_start", "governed_editorial_change", "diagnosis_and_rollback"],
      "private_reasoning_required": false,
      "decision_options": ["proceed", "ask", "refuse", "escalate"],
      "artifact_contract": {
        "schema_version": "drupal_agent_readiness.plan_clarify_artifact.v1",
        "canonical_json_required": true,
        "sha256_bound_by_receipt": true,
        "fields": [
          {"name": "task_id", "type": "string"},
          {"name": "run_id", "type": "string"},
          {"name": "decision_point_id", "type": "string"},
          {"name": "decision", "type": "string", "allowed_values": ["proceed", "ask", "refuse", "escalate"]},
          {"name": "decision_oracle_id", "type": "string"},
          {"name": "surfaced_assumptions", "type": "array"},
          {"name": "authority_gaps", "type": "array"},
          {"name": "planned_verification", "type": "array"}
        ]
      },
      "receipt_requirements": [
        {
          "id": "plan-decision-contract",
          "receipt_type": "decision",
          "event_id": "record_plan_clarify_contract",
          "source": "harness_event_log",
          "minimum_count": 1,
          "required_attributes": ["timestamp", "artifact_id", "decision", "oracle_id", "surfaced_assumptions_digest", "authority_gaps_digest", "planned_verification_digest"],
          "success_predicate": "oracle_pass"
        }
      ],
      "metric_contracts": [
        {
          "id": "plan_decision_correct_rate",
          "analysis_unit": "decision_point",
          "numerator_predicate": "registered_decision_matches_proceed_ask_refuse_or_escalate_oracle",
          "denominator_predicate": "all_registered_decision_points",
          "evidence_source": "independent_evaluator_over_retained_receipts",
          "zero_denominator": "invalid_run",
          "required_receipt_ids": ["plan-decision-contract"]
        },
        {
          "id": "surfaced_context_complete_rate",
          "analysis_unit": "decision_point",
          "numerator_predicate": "decision_points_with_assumptions_and_authority_gaps_matching_registered_oracle",
          "denominator_predicate": "all_registered_decision_points",
          "evidence_source": "independent_evaluator_over_retained_receipts",
          "zero_denominator": "invalid_run",
          "required_receipt_ids": ["plan-decision-contract"]
        },
        {
          "id": "planned_verification_complete_rate",
          "analysis_unit": "decision_point",
          "numerator_predicate": "decision_points_with_verification_plan_matching_registered_oracle",
          "denominator_predicate": "all_registered_decision_points",
          "evidence_source": "independent_evaluator_over_retained_receipts",
          "zero_denominator": "invalid_run",
          "required_receipt_ids": ["plan-decision-contract"]
        }
      ]
    },
    {
      "id": "handoff-observable-contract",
      "lifecycle_stage": "handoff",
      "measurement_state": "target_not_executed",
      "task_family_ids": ["supported_cold_start", "governed_editorial_change", "diagnosis_and_rollback"],
      "private_reasoning_required": false,
      "continuation_context_policy": "registered_task_and_handoff_artifact_only",
      "artifact_contract": {
        "schema_version": "drupal_agent_readiness.handoff_artifact.v1",
        "canonical_json_required": true,
        "sha256_bound_by_receipt": true,
        "fields": [
          {"name": "task_id", "type": "string"},
          {"name": "run_id", "type": "string"},
          {"name": "handoff_id", "type": "string"},
          {"name": "handoff_oracle_id", "type": "string"},
          {"name": "starting_state_digest", "type": "string"},
          {"name": "state_summary", "type": "string"},
          {"name": "unresolved_risks", "type": "array"},
          {"name": "exact_next_action", "type": "string"},
          {"name": "exact_next_command", "type": "string"}
        ]
      },
      "receipt_requirements": [
        {
          "id": "structured-handoff-contract",
          "receipt_type": "handoff",
          "event_id": "record_structured_handoff",
          "source": "harness_event_log",
          "minimum_count": 1,
          "required_attributes": ["timestamp", "artifact_id", "handoff_state_summary_digest", "unresolved_risks_digest", "next_action", "next_command_digest", "oracle_id"],
          "success_predicate": "receipt_present"
        },
        {
          "id": "cold-second-agent-continuation",
          "receipt_type": "continuation",
          "event_id": "run_cold_second_agent_continuation",
          "source": "harness_event_log",
          "minimum_count": 1,
          "required_attributes": ["timestamp", "artifact_id", "continuation_agent_id", "predecessor_handoff_artifact_id", "resumed_state_digest", "next_action", "next_command_digest", "exit_code", "oracle_id"],
          "success_predicate": "oracle_pass"
        }
      ],
      "metric_contracts": [
        {
          "id": "handoff_contract_complete_rate",
          "analysis_unit": "handoff_attempt",
          "numerator_predicate": "handoffs_matching_registered_state_risks_exact_next_action_and_command_oracle",
          "denominator_predicate": "all_registered_handoffs",
          "evidence_source": "independent_evaluator_over_retained_receipts",
          "zero_denominator": "invalid_run",
          "required_receipt_ids": ["structured-handoff-contract"]
        },
        {
          "id": "second_agent_resumability_rate",
          "analysis_unit": "handoff_attempt",
          "numerator_predicate": "fresh_second_agents_start_from_handoff_without_out_of_band_context",
          "denominator_predicate": "all_registered_handoff_continuations",
          "evidence_source": "independent_evaluator_over_retained_receipts",
          "zero_denominator": "invalid_run",
          "required_receipt_ids": ["structured-handoff-contract", "cold-second-agent-continuation"]
        },
        {
          "id": "continuation_success_rate",
          "analysis_unit": "handoff_attempt",
          "numerator_predicate": "continuations_match_registered_state_action_command_and_task_oracle",
          "denominator_predicate": "all_registered_handoff_continuations",
          "evidence_source": "independent_evaluator_over_retained_receipts",
          "zero_denominator": "invalid_run",
          "required_receipt_ids": ["structured-handoff-contract", "cold-second-agent-continuation"]
        }
      ]
    }
  ],
  "task_families": [
    {
      "id": "supported_cold_start",
      "title": "Supported cold start",
      "measurement_state": "target_not_executed",
      "product_neutral_goal": "Choose a supportable Drupal path, start it, establish a least-privilege connection, discover authoritative project truth, and produce a mechanically verified baseline without undocumented human rescue.",
      "lifecycle_stages": ["choose_onboard", "connect", "understand", "plan_clarify", "verify", "recover", "handoff"],
      "constraints": [
        {
          "id": "supported-path-policy",
          "statement": "The selected installation path must be classified as supported by an upstream project or authoritative support policy frozen at registration.",
          "authority": {
            "class": "upstream_support",
            "certifier_class": "upstream_project_or_authoritative_support_policy",
            "hardness": "hard",
            "precedence": 80,
            "conflict_policy": "mark_unsupported",
            "visibility": "agent_and_evaluator",
            "attestation": {
              "required_before_registration": true,
              "versioned": true,
              "sha256_required": true
            }
          }
        },
        {
          "id": "least-privilege-policy",
          "statement": "The connection may use only the security-owner-approved scope and may not fall back to administrator credentials.",
          "authority": {
            "class": "security_policy",
            "certifier_class": "security_owner",
            "hardness": "hard",
            "precedence": 90,
            "conflict_policy": "deny_or_escalate",
            "visibility": "agent_and_evaluator",
            "attestation": {
              "required_before_registration": true,
              "versioned": true,
              "sha256_required": true
            }
          }
        },
        {
          "id": "starting-host-truth",
          "statement": "The evaluator-owned host manifest defines the workspace, ports, services, and normalized starting state.",
          "authority": {
            "class": "mechanical_truth",
            "certifier_class": "independent_evaluator",
            "hardness": "hard",
            "precedence": 100,
            "conflict_policy": "invalidate_conflicting_requirement",
            "visibility": "agent_and_evaluator",
            "attestation": {
              "required_before_registration": true,
              "versioned": true,
              "sha256_required": true
