      "blog:all",
      "blog:latest",
      "projects:all",
      "projects:featured"
    ],
    "page_count": 7
  },
  "command_runner": "ddev drush",
  "content_model": {
    "bundles": [
      "blog",
      "page",
      "person_profile",
      "project"
    ],
    "moderation_enabled": true
  },
  "pathauto": {
    "enabled": true,
    "patterns": [
