      "claimed": true,
      "entity_type": "canvas_page",
      "owner_kind": "entity"
    },
    "/home": {
      "claimed": true,
      "entity_type": "canvas_page",
      "owner_kind": "entity"
    },
    "/node": {
      "claimed": true,
      "owner_kind": "route"
    }
  },
  "provenance": {
    "active_config_source": "database",
    "config_sync_status": "empty",
    "project_name": "drupal/cms",
    "project_version": "2.1.3",
    "site_template": "haven"
  }
}
