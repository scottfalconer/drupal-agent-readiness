{
  "canvas": {
    "embedded_listings": [
      {
        "component_id": "block.views_block.blog-all",
        "display_id": "all",
        "label": "Blog: All blog posts",
        "page_label": "Blog",
        "page_path": "/blog",
        "view_id": "blog"
      },
      {
        "component_id": "block.views_block.projects-all",
        "display_id": "all",
        "label": "Projects: All projects",
        "page_label": "Projects",
        "page_path": "/projects",
        "view_id": "projects"
      },
      {
        "component_id": "block.views_block.projects-featured",
        "display_id": "featured",
        "label": "Projects: Featured project",
        "page_label": "Projects",
        "page_path": "/projects",
        "view_id": "projects"
      },
      {
        "component_id": "block.views_block.blog-latest",
        "display_id": "latest",
        "label": "Blog: Latest blog posts",
        "page_label": "Home",
        "page_path": "/home",
        "view_id": "blog"
      }
    ],
    "page_count": 7
  },
  "command_runner": "vendor/bin/drush",
  "content_model": {
    "bundles": [
      {
        "bundle": "blog",
        "content_count": 3,
        "entity_type": "node",
        "label": "Blog post"
      },
      {
        "bundle": "page",
        "content_count": 2,
        "entity_type": "node",
        "label": "Utility page"
      },
      {
        "bundle": "person_profile",
        "content_count": 1,
        "entity_type": "node",
        "label": "Person profile"
      },
      {
        "bundle": "project",
        "content_count": 3,
        "entity_type": "node",
        "label": "Project"
      }
    ],
    "moderation_enabled": true
  },
  "pathauto": {
    "enabled": true,
    "patterns": [
      {
        "bundles": [
          "blog"
        ],
        "id": "blog_content",
        "label": "Blog content",
        "pattern": "/blog/[node:created:html_month]/[node:title]",
        "type": "canonical_entities:node",
        "weight": -5
      },
      {
        "bundles": [],
        "id": "menu_path",
        "label": "Menu Path",
        "pattern": "/[node:menu-link:parents:join-path]/[node:title]",
        "type": "canonical_entities:node",
        "weight": 10
      },
      {
        "bundles": [
          "page"
        ],
        "id": "page_content",
        "label": "Page content",
        "pattern": "/[node:title]",
        "type": "canonical_entities:node",
        "weight": -5
      },
      {
        "bundles": [
          "project"
        ],
        "id": "project_content",
        "label": "Project content",
        "pattern": "/projects/[node:created:html_month]/[node:title]",
        "type": "canonical_entities:node",
        "weight": -5
      }
    ]
  },
  "paths": {
    "/blog": {
      "claimed": true,
      "entity_type": "canvas_page",
      "owner_kind": "entity"
    },
    "/home": {
      "claimed": true,
      "entity_type": "canvas_page",
      "owner_kind": "entity"
    },
    "/node": {
      "claimed": false,
      "owner_kind": "unclaimed"
    }
  },
  "provenance": {
    "active_config_source": "database",
    "config_sync_status": "empty",
    "project_name": "drupal/cms",
    "project_version": "2.1.3",
    "site_template": "haven"
  }
}
